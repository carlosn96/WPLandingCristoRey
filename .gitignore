# ===========================================
# Ignorar TODO por defecto
# ===========================================
/*

# ===========================================
# Permitir archivos de configuración del repo
# ===========================================
!.gitignore
!.env.example
!README.md
# OPERATING_PROTOCOL.md es expresamente omitido para evitar subirlo a Git

# ===========================================
# Permitir carpeta automation/ y todo su contenido
# ===========================================
!automation/
!automation/**

# ===========================================
# Permitir carpeta scripts/ y todo su contenido
# ===========================================
!scripts/
!scripts/**

# ===========================================
# Permitir Tema Personalizado y Plugins Propios
# ===========================================
!wp-content/
wp-content/*

# 1. Tema personalizado
!wp-content/themes/
wp-content/themes/*
!wp-content/themes/cristorey/
!wp-content/themes/cristorey/**

# 2. Must-Use Plugins (lógica de backend)
!wp-content/mu-plugins/
!wp-content/mu-plugins/**

# 3. Custom Plugins & Core Integrations
!wp-content/plugins/
wp-content/plugins/*
!wp-content/plugins/verbum-image-manager/
!wp-content/plugins/wpforms-lite/
!wp-content/plugins/wp-google-maps/
!wp-content/plugins/seo-by-rank-math/
!wp-content/plugins/wordfence/
!wp-content/plugins/updraftplus/
!wp-content/plugins/w3-total-cache/

# ===========================================
# Excluir archivos generados dentro del tema
# ===========================================
wp-content/themes/cristorey/node_modules/

# ===========================================
# Excluir archivos sensibles siempre
# ===========================================
.env
*.log
.vscode/
.idea/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
